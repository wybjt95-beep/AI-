# 复制本文件为 .env 后填写服务端配置。
# 上线版不要在这里放某个用户的模型 API Key；每个用户应登录后配置自己的 API Key。

# 用于本地加密用户 API Key 和签名会话。生产环境必须使用强随机值并放在部署平台环境变量里。
APP_SECRET=

# 运行环境：local / production
APP_ENV=local

# 可选：指定启动端口
PORT=5176

# 可选：生产部署时建议挂载持久化目录，例如 /data
APP_DATA_DIR=.data

# 可选：会话有效期，默认 14 天
SESSION_MAX_AGE_SECONDS=1209600

# 生产 HTTPS 环境设为 true，本地 http 调试保持 false
COOKIE_SECURE=false
